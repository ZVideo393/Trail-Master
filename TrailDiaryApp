<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dirt Diary — MTB Ride Journal</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --soil: #2a1f14;
    --bark: #3d2b1a;
    --mud: #5c3d22;
    --trail: #8b5e3c;
    --dust: #c4924a;
    --sun: #e8b96a;
    --sky: #7ba7bc;
    --moss: #5a7a4a;
    --leaf: #7aab5a;
    --rock: #d4c9b8;
    --cream: #f5ede0;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Nunito', sans-serif;
    background: var(--soil);
    color: var(--cream);
    min-height: 100vh;
    background-image:
      radial-gradient(ellipse at 20% 0%, #3d2b1a88 0%, transparent 60%),
      radial-gradient(ellipse at 80% 100%, #5c3d2244 0%, transparent 60%);
  }

  /* Grain overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: 0.4;
  }

  .wrapper {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }

  /* Header */
  header {
    text-align: center;
    padding: 2.5rem 0 2rem;
    animation: fadeDown 0.7s ease both;
  }

  .logo-mark {
    font-size: 2.5rem;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  header h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 10vw, 5rem);
    letter-spacing: 0.05em;
    color: var(--sun);
    line-height: 0.9;
    text-shadow: 0 4px 24px #00000066;
  }

  header p {
    font-size: 0.8rem;
    font-weight: 300;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--dust);
    margin-top: 0.5rem;
  }

  /* Divider */
  .divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 2rem 0;
  }
  .divider::before, .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--mud), transparent);
  }
  .divider span {
    font-size: 1.1rem;
    color: var(--trail);
  }

  /* Cards */
  .card {
    background: var(--bark);
    border-radius: 16px;
    padding: 1.75rem;
    margin-bottom: 1.25rem;
    border: 1px solid #ffffff0d;
    box-shadow: 0 8px 32px #00000040;
    animation: fadeUp 0.5s ease both;
  }

  .card:nth-child(1) { animation-delay: 0.1s; }
  .card:nth-child(2) { animation-delay: 0.15s; }
  .card:nth-child(3) { animation-delay: 0.2s; }
  .card:nth-child(4) { animation-delay: 0.25s; }
  .card:nth-child(5) { animation-delay: 0.3s; }
  .card:nth-child(6) { animation-delay: 0.35s; }
  .card:nth-child(7) { animation-delay: 0.4s; }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .card-icon {
    font-size: 1.4rem;
    width: 40px;
    height: 40px;
    background: var(--mud);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .card-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.4rem;
    letter-spacing: 0.08em;
    color: var(--sun);
  }

  .card-subtitle {
    font-size: 0.72rem;
    color: var(--trail);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Form fields */
  .field-group {
    display: grid;
    gap: 0.85rem;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem;
  }

  @media (max-width: 480px) {
    .field-row { grid-template-columns: 1fr; }
  }

  label {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dust);
    margin-bottom: 0.35rem;
  }

  input[type="text"],
  input[type="date"],
  input[type="number"],
  input[type="time"],
  select,
  textarea {
    width: 100%;
    background: var(--soil);
    border: 1.5px solid var(--mud);
    border-radius: 10px;
    padding: 0.65rem 0.9rem;
    color: var(--cream);
    font-family: 'Nunito', sans-serif;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    -webkit-appearance: none;
  }

  input:focus, select:focus, textarea:focus {
    border-color: var(--dust);
    box-shadow: 0 0 0 3px #c4924a22;
  }

  textarea {
    resize: vertical;
    min-height: 90px;
    line-height: 1.6;
  }

  select option {
    background: var(--bark);
  }

  /* Pressure inputs */
  .pressure-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem;
  }

  .pressure-input-wrap {
    position: relative;
  }

  .pressure-input-wrap input {
    padding-right: 3rem;
  }

  .unit-badge {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--trail);
    letter-spacing: 0.05em;
    pointer-events: none;
  }

  /* Emoji feel picker */
  .feel-picker {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .feel-btn {
    background: var(--soil);
    border: 1.5px solid var(--mud);
    border-radius: 12px;
    padding: 0.5rem 0.85rem;
    cursor: pointer;
    font-size: 1.2rem;
    transition: all 0.15s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    color: var(--cream);
    font-family: 'Nunito', sans-serif;
    flex: 1;
    min-width: 70px;
  }

  .feel-btn span.feel-label {
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--trail);
    font-weight: 700;
  }

  .feel-btn:hover, .feel-btn.active {
    border-color: var(--dust);
    background: var(--mud);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px #00000040;
  }

  .feel-btn.active {
    border-color: var(--sun);
    background: #c4924a22;
  }

  .feel-btn.active span.feel-label {
    color: var(--sun);
  }

  /* Weather chips */
  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .chip {
    background: var(--soil);
    border: 1.5px solid var(--mud);
    border-radius: 20px;
    padding: 0.35rem 0.9rem;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s ease;
    color: var(--rock);
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .chip:hover, .chip.active {
    border-color: var(--sky);
    color: var(--sky);
    background: #7ba7bc18;
  }

  /* Tire condition chips */
  .chip.tire-chip:hover, .chip.tire-chip.active {
    border-color: var(--leaf);
    color: var(--leaf);
    background: #7aab5a18;
  }

  /* Trail rating stars */
  .star-row {
    display: flex;
    gap: 0.4rem;
  }

  .star-btn {
    font-size: 1.6rem;
    cursor: pointer;
    background: none;
    border: none;
    transition: transform 0.1s;
    filter: grayscale(1) opacity(0.3);
    padding: 0;
  }

  .star-btn.active {
    filter: none;
    transform: scale(1.15);
  }

  .star-btn:hover {
    filter: none;
  }


  /* Bike Garage */
  .bike-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 0.65rem;
    margin-bottom: 0.75rem;
  }

  .bike-tile {
    background: var(--soil);
    border: 1.5px solid var(--mud);
    border-radius: 12px;
    padding: 0.85rem 1rem;
    cursor: pointer;
    transition: all 0.15s ease;
    position: relative;
  }

  .bike-tile:hover { border-color: var(--trail); transform: translateY(-1px); }

  .bike-tile.selected {
    border-color: var(--sun);
    background: #c4924a18;
    box-shadow: 0 0 0 3px #c4924a22;
  }

  .bike-tile .bike-name {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--cream);
    margin-bottom: 2px;
  }

  .bike-tile .bike-meta {
    font-size: 0.72rem;
    color: var(--trail);
    line-height: 1.4;
  }

  .bike-tile .bike-delete {
    position: absolute;
    top: 0.5rem;
    right: 0.6rem;
    background: none;
    border: none;
    color: var(--mud);
    font-size: 0.85rem;
    cursor: pointer;
    transition: color 0.15s;
    line-height: 1;
    padding: 0;
  }

  .bike-tile .bike-delete:hover { color: #e05555; }

  .bike-tile.selected .bike-delete { color: var(--trail); }

  .garage-toggle {
    background: var(--mud);
    border: 1.5px solid var(--trail);
    border-radius: 8px;
    color: var(--sun);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1rem;
    letter-spacing: 0.07em;
    padding: 0.45rem 1rem;
    cursor: pointer;
    transition: background 0.15s;
    width: 100%;
    text-align: left;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .garage-toggle:hover { background: var(--trail); }

  .garage-form {
    background: var(--soil);
    border: 1.5px solid var(--mud);
    border-radius: 12px;
    padding: 1.1rem;
    margin-top: 0.75rem;
  }

  .selected-badge {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sun);
    background: #c4924a22;
    border-radius: 6px;
    padding: 2px 8px;
    display: inline-block;
    margin-top: 0.35rem;
  }

  /* Submit */
  .submit-btn {
    width: 100%;
    background: linear-gradient(135deg, var(--dust), var(--trail));
    border: none;
    border-radius: 14px;
    padding: 1.1rem;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    letter-spacing: 0.12em;
    color: var(--soil);
    cursor: pointer;
    margin-top: 1.5rem;
    transition: all 0.2s ease;
    box-shadow: 0 6px 24px #c4924a44;
  }

  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 32px #c4924a66;
  }

  .submit-btn:active {
    transform: translateY(0);
  }

  /* Past rides strip */
  .rides-strip {
    margin-top: 2.5rem;
    animation: fadeUp 0.6s 0.5s ease both;
  }

  .rides-strip h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.6rem;
    letter-spacing: 0.08em;
    color: var(--dust);
    margin-bottom: 1rem;
  }

  .ride-entry {
    background: var(--bark);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    margin-bottom: 0.65rem;
    border: 1px solid #ffffff08;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: background 0.15s;
    cursor: pointer;
  }

  .ride-entry:hover {
    background: var(--mud);
  }

  .ride-entry-info h3 {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--cream);
  }

  .ride-entry-info p {
    font-size: 0.75rem;
    color: var(--trail);
    margin-top: 2px;
  }

  .ride-entry-feel {
    font-size: 1.6rem;
  }

  /* Toast */
  .toast {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: var(--moss);
    color: white;
    padding: 0.8rem 1.75rem;
    border-radius: 50px;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    box-shadow: 0 8px 24px #00000060;
    transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
    z-index: 100;
  }

  .toast.show {
    transform: translateX(-50%) translateY(0);
  }

  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
</head>
<body>

<div class="wrapper">

  <!-- Header -->
  <header>
    <div class="logo-mark">🚵</div>
    <h1>Dirt Diary</h1>
    <p>Mountain Bike Ride Journal</p>
  </header>

  <form id="rideForm" onsubmit="saveRide(event)">

    <!-- 1. The Basics -->
    <div class="card">
      <div class="card-header">
        <div class="card-icon">📍</div>
        <div>
          <div class="card-title">The Basics</div>
          <div class="card-subtitle">Where & when did you ride?</div>
        </div>
      </div>
      <div class="field-group">
        <div class="field-row">
          <div>
            <label for="trailName">Trail / Area Name</label>
            <input type="text" id="trailName" placeholder="e.g. Pisgah National Forest" />
          </div>
          <div>
            <label for="rideDate">Date</label>
            <input type="date" id="rideDate" />
          </div>
        </div>
        <div class="field-row">
          <div>
            <label for="duration">Duration</label>
            <input type="text" id="duration" placeholder="e.g. 2h 30m" />
          </div>
          <div>
            <label for="distance">Distance (miles)</label>
            <input type="number" id="distance" placeholder="0.0" step="0.1" />
          </div>
        </div>
        <div>
          <label>Trail Rating</label>
          <div class="star-row" id="trailRating">
            <button type="button" class="star-btn" data-val="1" onclick="setStars(1)">⭐</button>
            <button type="button" class="star-btn" data-val="2" onclick="setStars(2)">⭐</button>
            <button type="button" class="star-btn" data-val="3" onclick="setStars(3)">⭐</button>
            <button type="button" class="star-btn" data-val="4" onclick="setStars(4)">⭐</button>
            <button type="button" class="star-btn" data-val="5" onclick="setStars(5)">⭐</button>
          </div>
        </div>

        <!-- Trails Ridden -->
        <div>
          <label>Trails You Rode Down</label>
          <div id="trailsList" style="display:flex; flex-direction:column; gap:0.5rem; margin-bottom:0.5rem;"></div>
          <div style="display:flex; gap:0.5rem;">
            <input type="text" id="trailInput" placeholder="e.g. Black Mountain Descent" style="flex:1;" onkeydown="if(event.key==='Enter'){event.preventDefault();addTrail();}" />
            <button type="button" onclick="addTrail()" style="
              background: var(--mud);
              border: 1.5px solid var(--trail);
              border-radius: 10px;
              color: var(--sun);
              font-family: 'Bebas Neue', sans-serif;
              font-size: 1.2rem;
              letter-spacing: 0.05em;
              padding: 0 1.1rem;
              cursor: pointer;
              transition: background 0.15s;
              white-space: nowrap;
            " onmouseover="this.style.background='var(--trail)'" onmouseout="this.style.background='var(--mud)'">+ Add</button>
          </div>
          <p style="font-size:0.7rem; color:var(--trail); margin-top:0.4rem; letter-spacing:0.04em;">Press Enter or click Add after each trail name</p>
        </div>
      </div>
    </div>

    <!-- 2. Weather -->
    <div class="card">
      <div class="card-header">
        <div class="card-icon">🌤</div>
        <div>
          <div class="card-title">Weather Conditions</div>
          <div class="card-subtitle">What was it like out there?</div>
        </div>
      </div>
      <div class="field-group">
        <div>
          <label>Conditions (pick all that apply)</label>
          <div class="chip-row" id="weatherChips">
            <div class="chip" onclick="toggleChip(this)">☀️ Sunny</div>
            <div class="chip" onclick="toggleChip(this)">⛅ Partly Cloudy</div>
            <div class="chip" onclick="toggleChip(this)">☁️ Overcast</div>
            <div class="chip" onclick="toggleChip(this)">🌧 Rainy</div>
            <div class="chip" onclick="toggleChip(this)">🌫 Foggy</div>
            <div class="chip" onclick="toggleChip(this)">💨 Windy</div>
            <div class="chip" onclick="toggleChip(this)">❄️ Cold</div>
            <div class="chip" onclick="toggleChip(this)">🥵 Hot</div>
          </div>
        </div>
        <div class="field-row">
          <div>
            <label for="tempF">Temperature (°F)</label>
            <input type="number" id="tempF" placeholder="72" />
          </div>
          <div>
            <label for="trailCondition">Trail Surface</label>
            <select id="trailCondition">
              <option value="">Select condition...</option>
              <option>Dry & dusty</option>
              <option>Tacky (perfect)</option>
              <option>Slightly damp</option>
              <option>Wet & muddy</option>
              <option>Loose over hard</option>
              <option>Hard pack</option>
              <option>Chunky / rocky</option>
            </select>
          </div>
        </div>
      </div>
    </div>


    <!-- 2b. Your Bike -->
    <div class="card">
      <div class="card-header">
        <div class="card-icon">🚲</div>
        <div>
          <div class="card-title">Your Bike</div>
          <div class="card-subtitle">Which rig did you ride?</div>
        </div>
      </div>
      <div class="field-group">

        <!-- Saved bikes grid -->
        <div>
          <label>Garage <span id="bikeCount" style="color:var(--trail);font-size:0.7rem;font-weight:400;">(0 bikes)</span></label>
          <div class="bike-card-grid" id="bikeGrid">
            <div style="font-size:0.82rem;color:var(--trail);padding:0.5rem 0;grid-column:1/-1;">No bikes saved yet — add one below.</div>
          </div>
          <div id="selectedBikeLabel"></div>
        </div>

        <!-- Add new bike toggle -->
        <div>
          <button type="button" class="garage-toggle" onclick="toggleGarageForm()">
            <span>+ Add a Bike to Garage</span>
            <span id="garageArrow">▾</span>
          </button>
          <div class="garage-form" id="garageForm" style="display:none;">
            <div class="field-group">
              <div class="field-row">
                <div>
                  <label for="newBikeName">Bike Name / Nickname</label>
                  <input type="text" id="newBikeName" placeholder="e.g. The Ripper" />
                </div>
                <div>
                  <label for="newBikeBrand">Brand & Model</label>
                  <input type="text" id="newBikeBrand" placeholder="e.g. Santa Cruz Megatower" />
                </div>
              </div>
              <div class="field-row">
                <div>
                  <label for="newBikeYear">Year</label>
                  <input type="number" id="newBikeYear" placeholder="2023" />
                </div>
                <div>
                  <label for="newBikeTravel">Travel (mm)</label>
                  <input type="number" id="newBikeTravel" placeholder="160" />
                </div>
              </div>
              <div>
                <label for="newBikeNotes">Notes (optional)</label>
                <input type="text" id="newBikeNotes" placeholder="e.g. size L, mullet build, custom bars" />
              </div>
              <button type="button" onclick="saveBike()" style="
                background: linear-gradient(135deg, var(--dust), var(--trail));
                border: none; border-radius: 10px; padding: 0.6rem 1.25rem;
                font-family: 'Bebas Neue', sans-serif; font-size: 1.1rem;
                letter-spacing: 0.08em; color: var(--soil); cursor: pointer;
                transition: all 0.15s ease; width: 100%;
              ">Save to Garage</button>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- 3. Bike Setup — Suspension -->
    <div class="card">
      <div class="card-header">
        <div class="card-icon">⚙️</div>
        <div>
          <div class="card-title">Suspension Setup</div>
          <div class="card-subtitle">Fork & shock pressures</div>
        </div>
      </div>
      <div class="field-group">
        <div class="field-row">
          <div>
            <label>Fork Pressure</label>
            <div class="pressure-input-wrap">
              <input type="number" id="forkPsi" placeholder="80" />
              <span class="unit-badge">PSI</span>
            </div>
          </div>
          <div>
            <label>Shock Pressure</label>
            <div class="pressure-input-wrap">
              <input type="number" id="shockPsi" placeholder="200" />
              <span class="unit-badge">PSI</span>
            </div>
          </div>
        </div>
        <div class="field-row">
          <div>
            <label for="forkClicks">Fork Rebound (clicks)</label>
            <input type="number" id="forkClicks" placeholder="8" />
          </div>
          <div>
            <label for="shockClicks">Shock Rebound (clicks)</label>
            <input type="number" id="shockClicks" placeholder="5" />
          </div>
        </div>
        <div>
          <label for="suspensionNotes">Suspension Feel Notes</label>
          <textarea id="suspensionNotes" placeholder="How did the fork feel on impact? Plush? Harsh? Bottomed out?"></textarea>
        </div>
      </div>
    </div>

    <!-- 4. Tires -->
    <div class="card">
      <div class="card-header">
        <div class="card-icon" style="background:none;border:none;width:48px;height:48px;flex-shrink:0;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="48" height="48" style="display:block;">
            <!-- Outer knobby tire -->
            <circle cx="50" cy="50" r="46" fill="none" stroke="#ffffff" stroke-width="7"/>
            <!-- Knobs around the tire (outer) -->
            <!-- We simulate knobs as small rectangles rotated around the rim -->
            <g stroke="#ffffff" stroke-width="3" stroke-linecap="round">
              <!-- Knob ticks at every 22.5 degrees, alternating lengths for knobby look -->
              <line x1="50" y1="4" x2="50" y2="0" transform="rotate(0 50 50)"/>
              <line x1="50" y1="4" x2="50" y2="0" transform="rotate(22.5 50 50)"/>
              <line x1="50" y1="5" x2="50" y2="0" transform="rotate(45 50 50)"/>
              <line x1="50" y1="4" x2="50" y2="0" transform="rotate(67.5 50 50)"/>
              <line x1="50" y1="5" x2="50" y2="0" transform="rotate(90 50 50)"/>
              <line x1="50" y1="4" x2="50" y2="0" transform="rotate(112.5 50 50)"/>
              <line x1="50" y1="5" x2="50" y2="0" transform="rotate(135 50 50)"/>
              <line x1="50" y1="4" x2="50" y2="0" transform="rotate(157.5 50 50)"/>
              <line x1="50" y1="5" x2="50" y2="0" transform="rotate(180 50 50)"/>
              <line x1="50" y1="4" x2="50" y2="0" transform="rotate(202.5 50 50)"/>
              <line x1="50" y1="5" x2="50" y2="0" transform="rotate(225 50 50)"/>
              <line x1="50" y1="4" x2="50" y2="0" transform="rotate(247.5 50 50)"/>
              <line x1="50" y1="5" x2="50" y2="0" transform="rotate(270 50 50)"/>
              <line x1="50" y1="4" x2="50" y2="0" transform="rotate(292.5 50 50)"/>
              <line x1="50" y1="5" x2="50" y2="0" transform="rotate(315 50 50)"/>
              <line x1="50" y1="4" x2="50" y2="0" transform="rotate(337.5 50 50)"/>
            </g>
            <!-- Inner rim wall -->
            <circle cx="50" cy="50" r="38" fill="none" stroke="#888" stroke-width="2"/>
            <!-- Rim bed -->
            <circle cx="50" cy="50" r="28" fill="none" stroke="#ffffff" stroke-width="3.5"/>
            <!-- Spokes - 8 spokes crossing hub -->
            <g stroke="#cccccc" stroke-width="1.5" stroke-linecap="round" opacity="0.85">
              <!-- Spoke 1 - slight offset for double-butted look -->
              <line x1="50" y1="29" x2="53" y2="22" transform="rotate(0 50 50)"/>
              <line x1="53" y1="22" x2="50" y2="50" transform="rotate(0 50 50)"/>
              <!-- Spoke 2 -->
              <line x1="50" y1="29" x2="53" y2="22" transform="rotate(45 50 50)"/>
              <line x1="53" y1="22" x2="50" y2="50" transform="rotate(45 50 50)"/>
              <!-- Spoke 3 -->
              <line x1="50" y1="29" x2="53" y2="22" transform="rotate(90 50 50)"/>
              <line x1="53" y1="22" x2="50" y2="50" transform="rotate(90 50 50)"/>
              <!-- Spoke 4 -->
              <line x1="50" y1="29" x2="53" y2="22" transform="rotate(135 50 50)"/>
              <line x1="53" y1="22" x2="50" y2="50" transform="rotate(135 50 50)"/>
              <!-- Spoke 5 -->
              <line x1="50" y1="29" x2="53" y2="22" transform="rotate(180 50 50)"/>
              <line x1="53" y1="22" x2="50" y2="50" transform="rotate(180 50 50)"/>
              <!-- Spoke 6 -->
              <line x1="50" y1="29" x2="53" y2="22" transform="rotate(225 50 50)"/>
              <line x1="53" y1="22" x2="50" y2="50" transform="rotate(225 50 50)"/>
              <!-- Spoke 7 -->
              <line x1="50" y1="29" x2="53" y2="22" transform="rotate(270 50 50)"/>
              <line x1="53" y1="22" x2="50" y2="50" transform="rotate(270 50 50)"/>
              <!-- Spoke 8 -->
              <line x1="50" y1="29" x2="53" y2="22" transform="rotate(315 50 50)"/>
              <line x1="53" y1="22" x2="50" y2="50" transform="rotate(315 50 50)"/>
            </g>
            <!-- Clean spokes from hub to rim (main straight spokes) -->
            <g stroke="#dddddd" stroke-width="1.2" opacity="0.7">
              <line x1="50" y1="50" x2="50" y2="22" transform="rotate(22.5 50 50)"/>
              <line x1="50" y1="50" x2="50" y2="22" transform="rotate(67.5 50 50)"/>
              <line x1="50" y1="50" x2="50" y2="22" transform="rotate(112.5 50 50)"/>
              <line x1="50" y1="50" x2="50" y2="22" transform="rotate(157.5 50 50)"/>
              <line x1="50" y1="50" x2="50" y2="22" transform="rotate(202.5 50 50)"/>
              <line x1="50" y1="50" x2="50" y2="22" transform="rotate(247.5 50 50)"/>
              <line x1="50" y1="50" x2="50" y2="22" transform="rotate(292.5 50 50)"/>
              <line x1="50" y1="50" x2="50" y2="22" transform="rotate(337.5 50 50)"/>
            </g>
            <!-- Hub outer ring -->
            <circle cx="50" cy="50" r="8" fill="#111" stroke="#ffffff" stroke-width="2.5"/>
            <!-- Hub center axle -->
            <circle cx="50" cy="50" r="3" fill="#ffffff"/>
            <!-- Valve stem -->
            <rect x="48.5" y="19" width="3" height="5" rx="1" fill="#aaa" transform="rotate(15 50 50)"/>
          </svg>
        </div>
        <div>
          <div class="card-title">Tires</div>
          <div class="card-subtitle">Rubber & pressures</div>
        </div>
      </div>
      <div class="field-group">
        <div class="field-row">
          <div>
            <label for="frontTire">Front Tire</label>
            <input type="text" id="frontTire" placeholder="e.g. Maxxis Assegai 2.5" />
          </div>
          <div>
            <label for="rearTire">Rear Tire</label>
            <input type="text" id="rearTire" placeholder="e.g. Maxxis DHR II 2.4" />
          </div>
        </div>
        <div class="field-row">
          <div>
            <label>Front Pressure</label>
            <div class="pressure-input-wrap">
              <input type="number" id="frontPsi" placeholder="22" step="0.5" />
              <span class="unit-badge">PSI</span>
            </div>
          </div>
          <div>
            <label>Rear Pressure</label>
            <div class="pressure-input-wrap">
              <input type="number" id="rearPsi" placeholder="25" step="0.5" />
              <span class="unit-badge">PSI</span>
            </div>
          </div>
        </div>
        <div>
          <label>Tire Performance</label>
          <div class="chip-row" id="tireChips">
            <div class="chip tire-chip" onclick="toggleChip(this)">🔒 Great grip</div>
            <div class="chip tire-chip" onclick="toggleChip(this)">💨 Fast rolling</div>
            <div class="chip tire-chip" onclick="toggleChip(this)">😬 Squirmy</div>
            <div class="chip tire-chip" onclick="toggleChip(this)">💪 Confident</div>
            <div class="chip tire-chip" onclick="toggleChip(this)">⬇️ Too low</div>
            <div class="chip tire-chip" onclick="toggleChip(this)">⬆️ Too high</div>
          </div>
        </div>
      </div>
    </div>

    <!-- 5. How You Felt -->
    <div class="card">
      <div class="card-header">
        <div class="card-icon">🧠</div>
        <div>
          <div class="card-title">How You Felt</div>
          <div class="card-subtitle">Body, mind & energy on the trail</div>
        </div>
      </div>
      <div class="field-group">
        <div>
          <label>Overall Ride Vibe</label>
          <div class="feel-picker">
            <button type="button" class="feel-btn" onclick="selectFeel(this, '🔥')">🔥<span class="feel-label">On Fire</span></button>
            <button type="button" class="feel-btn" onclick="selectFeel(this, '😎')">😎<span class="feel-label">Solid</span></button>
            <button type="button" class="feel-btn" onclick="selectFeel(this, '😐')">😐<span class="feel-label">Meh</span></button>
            <button type="button" class="feel-btn" onclick="selectFeel(this, '😓')">😓<span class="feel-label">Struggled</span></button>
            <button type="button" class="feel-btn" onclick="selectFeel(this, '💀')">💀<span class="feel-label">Cooked</span></button>
          </div>
          <input type="hidden" id="rideVibe" />
        </div>
        <div class="field-row">
          <div>
            <label for="energyLevel">Energy Level</label>
            <select id="energyLevel">
              <option value="">How were your legs?</option>
              <option>Fresh & powerful</option>
              <option>Good</option>
              <option>Average</option>
              <option>Heavy legs</option>
              <option>Completely gassed</option>
            </select>
          </div>
          <div>
            <label for="techConfidence">Tech Confidence</label>
            <select id="techConfidence">
              <option value="">Feeling on tech?</option>
              <option>Charging everything</option>
              <option>Comfortable</option>
              <option>Cautious</option>
              <option>Off my game</option>
              <option>Sketchy day</option>
            </select>
          </div>
        </div>
        <div>
          <label for="bodyNotes">Body Notes</label>
          <textarea id="bodyNotes" placeholder="Any aches, cramps, fatigue, highlights? How did your body hold up?"></textarea>
        </div>
      </div>
    </div>

    <!-- 6. The Story -->
    <div class="card">
      <div class="card-header">
        <div class="card-icon">✍️</div>
        <div>
          <div class="card-title">The Story</div>
          <div class="card-subtitle">Free-write your ride</div>
        </div>
      </div>
      <div class="field-group">
        <div>
          <label for="highlights">Best Moments</label>
          <textarea id="highlights" placeholder="That one line you finally cleaned, a jump that felt perfect, the view at the top..." style="min-height: 80px;"></textarea>
        </div>
        <div>
          <label for="improvements">What to Tweak Next Time</label>
          <textarea id="improvements" placeholder="Bike setup, pacing, lines to practice, areas to dial in..." style="min-height: 80px;"></textarea>
        </div>
        <div>
          <label for="generalNotes">Anything Else</label>
          <textarea id="generalNotes" placeholder="Trail conditions you want to remember, riding buddies, post-ride feels..." style="min-height: 70px;"></textarea>
        </div>
      </div>
    </div>

    <button type="submit" class="submit-btn">🏁 Save Ride Entry</button>

  </form>

  <!-- Past Rides -->
  <div class="rides-strip">
    <div class="divider"><span>🌲</span></div>
    <h2>Past Rides</h2>
    <div id="pastRides">
      <!-- Sample entries -->
      <div class="ride-entry">
        <div class="ride-entry-info">
          <h3>Pisgah — Black Mountain Loop</h3>
          <p>Feb 18 · 22.4 mi · Tacky, perfect</p>
        </div>
        <div class="ride-entry-feel">🔥</div>
      </div>
      <div class="ride-entry">
        <div class="ride-entry-info">
          <h3>Dupont State Forest</h3>
          <p>Feb 10 · 15.1 mi · Slightly damp</p>
        </div>
        <div class="ride-entry-feel">😎</div>
      </div>
      <div class="ride-entry">
        <div class="ride-entry-info">
          <h3>Local Trails — Backyard Shred</h3>
          <p>Feb 4 · 8.0 mi · Dry & dusty</p>
        </div>
        <div class="ride-entry-feel">😐</div>
      </div>
    </div>
  </div>

</div>

<!-- Toast -->
<div class="toast" id="toast">✅ Ride saved to your diary!</div>

<script>
  // ── Bike Garage ──────────────────────────────────────────────────────────
  let bikeGarage = JSON.parse(localStorage.getItem('dirtDiaryGarage') || '[]');
  let selectedBikeId = null;
  let garageOpen = false;

  function saveGarage() {
    localStorage.setItem('dirtDiaryGarage', JSON.stringify(bikeGarage));
  }

  function renderGarage() {
    const grid = document.getElementById('bikeGrid');
    const count = document.getElementById('bikeCount');
    count.textContent = '(' + bikeGarage.length + ' bike' + (bikeGarage.length !== 1 ? 's' : '') + ')';

    if (bikeGarage.length === 0) {
      grid.innerHTML = '<div style="font-size:0.82rem;color:var(--trail);padding:0.5rem 0;grid-column:1/-1;">No bikes saved yet — add one below.</div>';
      return;
    }

    grid.innerHTML = '';
    bikeGarage.forEach(function(b) {
      const tile = document.createElement('div');
      tile.className = 'bike-tile' + (selectedBikeId === b.id ? ' selected' : '');
      tile.innerHTML =
        '<button class="bike-delete" type="button" title="Remove">&#x2715;</button>' +
        '<div class="bike-name">' + b.name + '</div>' +
        '<div class="bike-meta">' +
          (b.brand || '') +
          (b.year ? ' &middot; ' + b.year : '') +
          (b.travel ? '<br>' + b.travel + 'mm travel' : '') +
          (b.notes ? '<br>' + b.notes : '') +
        '</div>';
      tile.querySelector('.bike-delete').addEventListener('click', function(e) {
        e.stopPropagation();
        deleteBike(b.id);
      });
      tile.addEventListener('click', function() { selectBike(b.id); });
      grid.appendChild(tile);
    });
  }

  function selectBike(id) {
    selectedBikeId = selectedBikeId === id ? null : id;
    renderGarage();
    const bike = bikeGarage.find(function(b) { return b.id === id; });
    const label = document.getElementById('selectedBikeLabel');
    if (bike && selectedBikeId) {
      label.innerHTML = '<span class="selected-badge">&#x2713; Riding: ' + bike.name + '</span>';
    } else {
      label.innerHTML = '';
    }
  }

  function deleteBike(id) {
    bikeGarage = bikeGarage.filter(function(b) { return b.id !== id; });
    if (selectedBikeId === id) {
      selectedBikeId = null;
      document.getElementById('selectedBikeLabel').innerHTML = '';
    }
    saveGarage();
    renderGarage();
  }

  function saveBike() {
    const name = document.getElementById('newBikeName').value.trim();
    const brand = document.getElementById('newBikeBrand').value.trim();
    const year = document.getElementById('newBikeYear').value.trim();
    const travel = document.getElementById('newBikeTravel').value.trim();
    const notes = document.getElementById('newBikeNotes').value.trim();
    if (!name) { document.getElementById('newBikeName').focus(); return; }
    const bike = { id: Date.now().toString(), name: name, brand: brand, year: year, travel: travel, notes: notes };
    bikeGarage.push(bike);
    saveGarage();
    renderGarage();
    selectBike(bike.id);
    ['newBikeName','newBikeBrand','newBikeYear','newBikeTravel','newBikeNotes'].forEach(function(id) {
      document.getElementById(id).value = '';
    });
    toggleGarageForm(false);
  }

  function toggleGarageForm(forceClose) {
    garageOpen = forceClose === false ? false : !garageOpen;
    document.getElementById('garageForm').style.display = garageOpen ? 'block' : 'none';
    document.getElementById('garageArrow').textContent = garageOpen ? '\u25b4' : '\u25be';
  }

  renderGarage();

  // Set today's date
  document.getElementById('rideDate').valueAsDate = new Date();

  let starRating = 0;
  let rideVibe = '';
  let trailsRidden = [];

  function addTrail() {
    const input = document.getElementById('trailInput');
    const val = input.value.trim();
    if (!val) return;
    trailsRidden.push(val);
    renderTrails();
    input.value = '';
    input.focus();
  }

  function removeTrail(idx) {
    trailsRidden.splice(idx, 1);
    renderTrails();
  }

  function renderTrails() {
    const list = document.getElementById('trailsList');
    if (!list) return;
    list.innerHTML = '';
    trailsRidden.forEach(function(t, i) {
      const row = document.createElement('div');
      row.style.cssText = 'display:flex;align-items:center;justify-content:space-between;background:var(--soil);border:1.5px solid var(--mud);border-radius:8px;padding:0.5rem 0.75rem;font-size:0.9rem;color:var(--cream);';
      const span = document.createElement('span');
      span.textContent = '\uD83C\uDFD4 ' + t;
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.innerHTML = '&#x2715;';
      btn.style.cssText = 'background:none;border:none;color:var(--trail);font-size:1rem;cursor:pointer;padding:0 0.25rem;line-height:1;';
      btn.addEventListener('mouseenter', function() { this.style.color = '#e05555'; });
      btn.addEventListener('mouseleave', function() { this.style.color = 'var(--trail)'; });
      btn.addEventListener('click', function() { removeTrail(i); });
      row.appendChild(span);
      row.appendChild(btn);
      list.appendChild(row);
    });
  }

  function setStars(n) {
    starRating = n;
    document.querySelectorAll('.star-btn').forEach(function(btn, i) {
      btn.classList.toggle('active', i < n);
    });
  }

  function selectFeel(el, emoji) {
    document.querySelectorAll('.feel-btn').forEach(function(b) { b.classList.remove('active'); });
    el.classList.add('active');
    rideVibe = emoji;
    document.getElementById('rideVibe').value = emoji;
  }

  function toggleChip(el) {
    el.classList.toggle('active');
  }

  function saveRide(e) {
    e.preventDefault();
    const trail = document.getElementById('trailName').value.trim();
    const date = document.getElementById('rideDate').value;
    const dist = document.getElementById('distance').value;
    const surface = document.getElementById('trailCondition').value;
    const feel = rideVibe || '\uD83D\uDE10';

    if (!trail) { document.getElementById('trailName').focus(); return; }

    const entry = document.createElement('div');
    entry.className = 'ride-entry';
    const dateStr = date ? new Date(date + 'T12:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : 'Today';
    entry.innerHTML =
      '<div class="ride-entry-info">' +
        '<h3>' + trail + '</h3>' +
        '<p>' + dateStr + (dist ? ' \u00b7 ' + dist + ' mi' : '') + (surface ? ' \u00b7 ' + surface : '') + '</p>' +
      '</div>' +
      '<div class="ride-entry-feel">' + feel + '</div>';

    const pastRides = document.getElementById('pastRides');
    pastRides.insertBefore(entry, pastRides.firstChild);

    e.target.reset();
    document.getElementById('rideDate').valueAsDate = new Date();
    document.querySelectorAll('.chip.active').forEach(function(c) { c.classList.remove('active'); });
    document.querySelectorAll('.feel-btn.active').forEach(function(b) { b.classList.remove('active'); });
    document.querySelectorAll('.star-btn.active').forEach(function(b) { b.classList.remove('active'); });
    starRating = 0;
    rideVibe = '';
    trailsRidden = [];
    renderTrails();

    const toast = document.getElementById('toast');
    toast.classList.add('show');
    setTimeout(function() { toast.classList.remove('show'); }, 3000);
    setTimeout(function() { document.querySelector('.rides-strip').scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 200);
  }
</script>

</body>
</html>
